# Environment Configuration for Real-Time Reconciliation System
# Copy this file to .env before running docker-compose

# Kafka Configuration
KAFKA_BROKERS=kafka:29092
KAFKA_EXTERNAL_BROKERS=localhost:9092

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# API Configuration
API_PORT=3001
WEBSOCKET_PORT=8080

# Frontend Configuration
FRONTEND_PORT=3000
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:8080

# Node Environment
NODE_ENV=production

# Reconciliation Thresholds
T1_LATE_MS=15000
T2_MISSING_MS=60000
TIME_DRIFT_THRESHOLD_MS=60000

# Logging
LOG_LEVEL=info
